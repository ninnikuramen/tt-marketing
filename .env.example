# ============================================================
# Sunbrd Marketing Site — Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================================

# Resend — for the waitlist form
# Get an API key: https://resend.com/api-keys
# Create an audience for the waitlist: https://resend.com/audiences
# (The form will still work in dev without these — it'll skip sending
# and log a warning instead.)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_WAITLIST_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: only if you need to override the site URL in dev
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
